# ── VIZORIA AI — Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── SUPABASE (CLIENT-SAFE: embedded in JS bundle) ─────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The public URL of the app (used to build OAuth redirect URIs)
VITE_APP_URL=http://localhost:3000

# ── SUPABASE (SERVER-ONLY: never sent to browser) ─────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # ⚠️  KEEP SECRET

# The public URL of the app (server-side, used for email redirect links)
APP_URL=http://localhost:3000

# ── PRODUCTION VALUES ──────────────────────────────────────────────────────────
# In Vercel/Netlify/Fly.io, set these as environment variables in the dashboard.
# VITE_APP_URL=https://vizoria.ai
# APP_URL=https://vizoria.ai
